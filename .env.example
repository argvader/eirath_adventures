# Copy this file to .env and fill in your real values.
# .env is git-ignored so your secrets stay out of the repo.

# Deepgram API key — used to transcribe/diarize session audio.
# Get one at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# OpenAI API key — used by bin/gen-image.py to generate scene/location/hero art.
# Get one at https://platform.openai.com/api-keys (org must be verified for gpt-image-1).
OPENAI_API_KEY=
